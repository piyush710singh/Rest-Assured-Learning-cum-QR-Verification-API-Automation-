{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "success",
    "verification_status",
    "verification_type",
    "name",
    "gender",
    "dob",
    "care_of",
    "aadhaar_last4",
    "reference_id",
    "photo_available",
    "address",
    "qr_data",
    "metadata"
  ],
  "properties": {
    "success": {
      "type": "boolean"
    },
    "verification_status": {
      "type": "string"
    },
    "verification_type": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "gender": {
      "type": "string"
    },
    "dob": {
      "type": "string"
    },
    "care_of": {
      "type": "string"
    },
    "aadhaar_last4": {
      "type": "string",
      "pattern": "^\\d{4}$"
    },
    "reference_id": {
      "type": "string"
    },
    "photo_available": {
      "type": "boolean"
    },
    "address": {
      "type": "object",
      "required": [
        "house",
        "street",
        "landmark",
        "location",
        "vtc",
        "district",
        "sub_district",
        "state",
        "pin_code",
        "post_office"
      ],
      "properties": {
        "house": { "type": "string" },
        "street": { "type": "string" },
        "landmark": { "type": "string" },
        "location": { "type": "string" },
        "vtc": { "type": "string" },
        "district": { "type": "string" },
        "sub_district": { "type": "string" },
        "state": { "type": "string" },
        "pin_code": { "type": "string" },
        "post_office": { "type": "string" }
      },
      "additionalProperties": true
    },
    "qr_data": {
      "type": "object",
      "required": [
        "reference_id",
        "version",
        "email_mobile_indicator",
        "name",
        "dob",
        "gender",
        "care_of",
        "district",
        "landmark",
        "house",
        "location",
        "pin_code",
        "post_office",
        "state",
        "street",
        "sub_district",
        "vtc",
        "masked_aadhaar"
      ],
      "properties": {
        "reference_id": { "type": "string" },
        "version": { "type": "string" },
        "email_mobile_indicator": { "type": "string" },
        "name": { "type": "string" },
        "dob": { "type": "string" },
        "gender": { "type": "string" },
        "care_of": { "type": "string" },
        "district": { "type": "string" },
        "landmark": { "type": "string" },
        "house": { "type": "string" },
        "location": { "type": "string" },
        "pin_code": { "type": "string" },
        "post_office": { "type": "string" },
        "state": { "type": "string" },
        "street": { "type": "string" },
        "sub_district": { "type": "string" },
        "vtc": { "type": "string" },
        "masked_aadhaar": {
          "type": "string",
          "pattern": "^X{6}\\d{4}$"
        }
      },
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "required": [
        "trust_level",
        "qr_format",
        "signature_verified",
        "signature_verification_available",
        "pdf_signature_present",
        "pdf_signature_verified",
        "pdf_signature_summary",
        "ocr_used",
        "ocr_available"
      ],
      "properties": {
        "trust_level": { "type": "string" },
        "qr_format": { "type": "string" },
        "signature_verified": { "type": "boolean" },
        "signature_verification_available": { "type": "boolean" },
        "pdf_signature_present": { "type": "boolean" },
        "pdf_signature_verified": { "type": "boolean" },
        "pdf_signature_summary": { "type": "string" },
        "ocr_used": { "type": "boolean" },
        "ocr_available": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
